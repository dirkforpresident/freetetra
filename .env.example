# ============================================================
# FreeTetra Server — example configuration
# Copy to .env and adjust. Most values are sensible defaults.
# Only FEDERATION_NAME and (optionally) OPERATOR_* really need
# to be set for a fresh install.
# ============================================================

# --- Server ---
BREW_MODE=server
HTTP_LISTEN_ADDR=127.0.0.1:8091
BREW_SERVER_PATH=/brew
BREW_SERVER_REALM=brew
# Shared password for all RadioID-verified BlueStations.
# Documented publicly so anyone with a RadioID can connect.
BREW_SERVER_PASSWORD=blafablafa

# --- RadioID auto-auth ---
# Any ISSI registered on radioid.net is accepted automatically.
RADIOID_AUTH_ENABLED=true
RADIOID_SHARED_KEY=blafablafa
RADIOID_SYNC_ON_START=true
RADIOID_SYNC_EVERY=24h
RADIOID_USERS_FILE=./users.txt

# Offline mode: get the user DB from a peer instead of radioid.net.
# Useful for HamNet or isolated networks.
# RADIOID_OFFLINE_MODE=true

# --- Federation ---
FEDERATION_ENABLED=true

# Your server's name as shown to peers. Use your callsign or a
# cluster name like "HH-Cluster".
FEDERATION_NAME=YOUR_CALLSIGN

# Public open-federation key. Keep this exact value to peer with
# freetetra.de and the rest of the public FreeTetra network.
# Pick a different value for a closed/private mesh.
FEDERATION_KEY=freetetra-federation-2026

# This server's own WSS URL — used for gossip so other peers can
# discover and reach you.
FEDERATION_SELF_URL=wss://your-server.tld/peer/

# Comma-separated list of peer URLs to connect to. One seed is
# enough; the rest comes via gossip.
FEDERATION_PEERS=wss://freetetra.de/peer/

# --- Operator info (shown on landing page) ---
OPERATOR_NAME=YOUR_CALLSIGN
OPERATOR_CONTACT=you@example.com
OPERATOR_DESCRIPTION=Short text about who runs this server and for whom.

# --- APRS-IS forwarding ---
# Decode LIP position SDS and forward to APRS-IS.
APRS_ENABLED=false
# APRS_CALLSIGN=YOUR_CALLSIGN
# APRS_PASSCODE=CALCULATED_PASSCODE
# APRS_SERVER=euro.aprs2.net:14580

# --- Echo / parrot bot (separate process: tetra-brew-echo) ---
# By convention echo runs on a local TG (1-9) so it doesn't
# create federation ping-pong with other servers' echo bots.
ECHO_TALKGROUP=9
ECHO_BREW_ISSI=900002
ECHO_SOURCE_ISSI=900002
ECHO_PLAYBACK_DELAY=100ms
ECHO_FRAME_INTERVAL=60ms

# --- Webradio (separate process: tetra-brew-webradio) ---
# WEBRADIO_ENABLED=true
# WEBRADIO_STREAM_URL=https://st01.sslstream.dlf.de/dlf/01/128/mp3/stream.mp3
# WEBRADIO_TALKGROUP=24
# WEBRADIO_SOURCE_ISSI=900001
# WEBRADIO_ENCODER_BIN=./tetra-acelp-stdio
# WEBRADIO_FFMPEG_BIN=ffmpeg
# WEBRADIO_ENCODER_FRAME_SIZE=18

# --- DMR / BrandMeister bridge (separate process: tetra-brew-dmrbridge) ---
# Bridges TG 91+ between FreeTetra and the BrandMeister side via
# the TetraPack core. Only one operator per federation should run
# this — TG 91+ traffic is federated, so all peers see BM traffic
# via the bridge.
# DMRBRIDGE_FT_BASE_URL=http://127.0.0.1:8091
# DMRBRIDGE_BM_BASE_URL=http://127.0.0.1:8090
# DMRBRIDGE_FT_SOURCE=YOUR_BRIDGE_ISSI
# DMRBRIDGE_BM_SOURCE=YOUR_BRANDMEISTER_HOTSPOT_ID
# DMRBRIDGE_TGS=91,262,2621,2622,9990

# --- MOTD (welcome message via SDS) ---
# MOTD_ENABLED=false
# MOTD_TEXT=Welcome to FreeTetra
# MOTD_DB_PATH=data/motd_seen.db

# --- Advanced (usually not needed) ---
# BREW_SERVER_USERNAME=static-user
# BREW_SERVER_TOKEN_TTL=2m
# BREW_SERVER_PING_INTERVAL=5s
# BREW_SERVER_PONG_TIMEOUT=45s
# USER_AGENT=FreeTetra/1.0
# RECONNECT_DELAY=2s
