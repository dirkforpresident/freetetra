# Runtime role hint (router|webradio|zello). Entry point binary controls behavior.
BREW_MODE=server

# server/hybrid mode (inbound Brew server)
BREW_SERVER_PATH=/brew
BREW_SERVER_REALM=TETRA Homebrew
BREW_SERVER_USERNAME=your-user
BREW_SERVER_PASSWORD=your-pass
BREW_SERVER_TOKEN_TTL=2m
BREW_SERVER_PING_INTERVAL=5s
BREW_SERVER_PONG_TIMEOUT=45s
BREW_SERVER_WRITE_TIMEOUT=5s

# module-client mode (outbound Brew client toward routing plane)
BREW_CLIENT_BASE_URL=http://127.0.0.1:8080
BREW_CLIENT_PATH=/brew
BREW_CLIENT_USERNAME=
BREW_CLIENT_PASSWORD=
BREW_CLIENT_RECONNECT_DELAY=3s
BREW_CLIENT_DISCOVERY_TIMEOUT=5s
BREW_CLIENT_WRITE_TIMEOUT=5s

HTTP_LISTEN_ADDR=:8080
USER_AGENT=tetra-brew-backend/0.1

MQTT_ENABLED=true
MQTT_BROKER=tcp://127.0.0.1:1883
MQTT_CLIENT_ID=brew-backend-dev
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=0

MQTT_ACELP_UP_TOPIC=brew/calls/+/acelp/up
MQTT_ACELP_DOWN_TOPIC_TEMPLATE=brew/calls/%s/acelp/down

# tetra-netstack/go-ltes-compatible live call bridge
NETSTACK_BRIDGE_ENABLED=false
NETSTACK_ROUTE_FILE=./netstack-routes.example.json
NETSTACK_CALL_TOPIC=live/+/+/call/+/+
NETSTACK_TRAFFIC_TOPIC=live/+/+/traffic/+
NETSTACK_TRAFFIC_ENCODING=hex
NETSTACK_MIN_TRAFFIC_FRAMES=8
NETSTACK_PENDING_MAX_AGE=2s
NETSTACK_ROUTE_CALL_TIMEOUT=30s
NETSTACK_ENCODER_MODE=passthrough
# NETSTACK_ENCODER_URL=http://127.0.0.1:25700/encode
NETSTACK_ENCODER_TIMEOUT=2s
NETSTACK_RELEASE_CAUSE=0

# webradio -> tetra-acelp -> Brew talkgroup bridge
WEBRADIO_ENABLED=false
WEBRADIO_STREAM_URL=
WEBRADIO_TALKGROUP=15002
WEBRADIO_SOURCE_ISSI=899001
WEBRADIO_BREW_ISSI=0
WEBRADIO_FFMPEG_BIN=ffmpeg
# Expected stdin/stdout encoder binary. Input: 8kHz mono s16le PCM on stdin.
# Output: fixed-size codec frames on stdout (default 18-byte tetra-acelp frame).
WEBRADIO_ENCODER_BIN=./_other_repos_/tetra-acelp/tetra-acelp-stdio
WEBRADIO_ENCODER_ARGS=
WEBRADIO_ENCODER_FRAME_SIZE=18
WEBRADIO_RECONNECT_DELAY=3s
WEBRADIO_RELEASE_CAUSE=0

# zello websocket connector
ZELLO_ENABLED=false
ZELLO_WS_URL=
ZELLO_USERNAME=
ZELLO_PASSWORD=
ZELLO_CHANNELS=
ZELLO_CHANNEL_GSSI_MAP=
ZELLO_BREW_ISSI=899001

ZELLO_SOURCE_ISSI_BASE=800000
ZELLO_CODEC_SAMPLE_RATE=8000
ZELLO_CODEC_FRAMES_PER_PACKET=1
ZELLO_CODEC_FRAME_SIZE=60
ZELLO_CODEC_PACKET_DURATION_MS=20
ZELLO_TRANSCODE_TRAFFIC=true
ZELLO_TRAFFIC_DECODER_BIN=./_other_repos_/tetra-acelp/tetra-acelp-stdio-decoder
ZELLO_TRAFFIC_FFMPEG_BIN=ffmpeg
ZELLO_TRAFFIC_FFMPEG_ARGS=
ZELLO_TRAFFIC_ENCODER_BIN=./_other_repos_/tetra-acelp/tetra-acelp-stdio
ZELLO_TRAFFIC_ENCODER_ARGS=
ZELLO_TRAFFIC_ENCODER_FRAME_SIZE=18
ZELLO_LISTEN_ONLY=true
ZELLO_PLATFORM_TYPE=tetra-brew
ZELLO_PLATFORM_NAME=tetra-brew-mockup
ZELLO_RECONNECT_DELAY=5s
ZELLO_RESPONSE_TIMEOUT=10s

# echo loopback module (mirrors traffic audio on one TG back to caller)
ECHO_TALKGROUP=10002
ECHO_BREW_ISSI=899002
# virtual circuit endpoint ISSI for duplex echo over the router (0 = disabled)
ECHO_VIRTUAL_ISSI=0
# 0 = reuse source ISSI from captured call
ECHO_SOURCE_ISSI=0
ECHO_PLAYBACK_DELAY=300ms
ECHO_FRAME_INTERVAL=60ms
ECHO_RELEASE_CAUSE=0
ECHO_MAX_FRAMES=2000

RECONNECT_DELAY=2s
