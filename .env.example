# ============================================================
# FreeTetra Server — Beispiel-Konfiguration
# Kopiere diese Datei nach .env und passe sie an.
# ============================================================

# --- Server ---
BREW_MODE=server
HTTP_LISTEN_ADDR=127.0.0.1:8080
BREW_SERVER_PATH=/brew
BREW_SERVER_REALM=brew
BREW_SERVER_PASSWORD=blafablafa

# --- RadioID Auto-Auth ---
# Jede bei radioid.net registrierte ISSI darf sich verbinden.
RADIOID_AUTH_ENABLED=true
RADIOID_SHARED_KEY=blafablafa

# --- Federation ---
FEDERATION_ENABLED=true
FEDERATION_NAME=DEIN_RUFZEICHEN
FEDERATION_KEY=blafablafa
# Komma-getrennte Liste von Peer-Server URLs:
# FEDERATION_PEERS=wss://freetetra.1xx.is/peer/

# --- APRS-IS ---
# Positionen automatisch an aprs.fi senden
APRS_ENABLED=false
# APRS_CALLSIGN=DEIN_RUFZEICHEN
# APRS_PASSCODE=DEIN_PASSCODE
# APRS_SERVER=euro.aprs2.net:14580

# --- Echo / Papagei ---
ECHO_TALKGROUP=10002
ECHO_BREW_ISSI=899002
ECHO_PLAYBACK_DELAY=300ms

# --- Webradio (separater Prozess: tetra-brew-webradio) ---
# WEBRADIO_ENABLED=true
# WEBRADIO_STREAM_URL=https://st01.sslstream.dlf.de/dlf/01/128/mp3/stream.mp3
# WEBRADIO_TALKGROUP=887
# WEBRADIO_SOURCE_ISSI=900001
# WEBRADIO_ENCODER_BIN=./tetra-acelp-stdio
# WEBRADIO_FFMPEG_BIN=ffmpeg
# WEBRADIO_ENCODER_FRAME_SIZE=18

# --- Erweitert (normalerweise nicht noetig) ---
# BREW_SERVER_USERNAME=statischer-user
# BREW_SERVER_TOKEN_TTL=2m
# BREW_SERVER_PING_INTERVAL=5s
# BREW_SERVER_PONG_TIMEOUT=45s
# USER_AGENT=FreeTetra/1.0
# RECONNECT_DELAY=2s
