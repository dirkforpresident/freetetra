# Settings for the optional DMR/BrandMeister bridge (TG 91+).
# Copy to .env.dmrbridge and fill in.
#
# Start with: docker compose --profile dmrbridge up -d dmrbridge

# Credentials for the FreeTetra Brew endpoint the bridge connects to.
# Must be a valid subscriber on the FreeTetra side.
DMRBRIDGE_FT_USER=
DMRBRIDGE_FT_PASS=
DMRBRIDGE_FT_ISSI=905001

# Credentials for the BrandMeister-facing TetraPack core.
# DMRBRIDGE_BM_ISSI is derived from DMRBRIDGE_BM_USER if left blank.
DMRBRIDGE_BM_USER=
DMRBRIDGE_BM_PASS=
DMRBRIDGE_BM_ISSI=

# Optional source-ISSI rewrite when BM rejects calls because the TETRA
# subscriber ID doesn't match a registered hotspot. Leave at 0 to pass
# the original source through.
DMRBRIDGE_BM_SOURCE_OVERRIDE=0
DMRBRIDGE_FT_SOURCE_OVERRIDE=0

# Set DMRBRIDGE_REQUIRE_RADIOID=false to let every FT subscriber TX into
# BM. Default (compose) keeps it true — only valid DMR IDs cross over.
# DMRBRIDGE_REQUIRE_RADIOID=true
